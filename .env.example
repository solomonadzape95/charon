# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Agent (OpenRouter, OpenAI-compatible) ────────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Any model slug from openrouter.ai/models. Free options:
#   qwen/qwen3-next-80b-a3b-instruct:free  (default)
#   meta-llama/llama-3.3-70b-instruct:free
#   qwen/qwen3-coder:free
OPENROUTER_MODEL=qwen/qwen3-next-80b-a3b-instruct:free

# ── Telegram bot ──────────────────────────────────────────
# Create a bot with @BotFather, paste the token here.
TELEGRAM_BOT_TOKEN=123456:ABC...
# Random secret guarding the webhook endpoint (set as Telegram secret_token).
TELEGRAM_WEBHOOK_SECRET=some-random-string

# ── Arc / Circle x402 settlement (pooled reader treasury) ──
# Run `npm run generate-wallets` to create these, then fund the
# addresses at https://faucet.circle.com (select "Arc Testnet").
# The TREASURY wallet holds all readers' deposited USDC and is the
# x402 payer for direct-route tips and escrow funding.
TREASURY_WALLET_PK=0x...
TREASURY_WALLET_ADDRESS=0x...

# ── Circle Programmable Wallets (creator escrow) ──────────
# Developer-controlled wallets API. https://console.circle.com
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
# Blockchain for escrow wallets (e.g. ARB-SEPOLIA / MATIC-AMOY in sandbox).
CIRCLE_WALLET_BLOCKCHAIN=ARB-SEPOLIA

# ── Email (creator claim notifications) ───────────────────
RESEND_API_KEY=
RESEND_FROM="Charon <tips@charon.app>"

# ── Identity resolution ───────────────────────────────────
# Optional but recommended (higher GitHub rate limit, Farcaster lookups).
GITHUB_TOKEN=
NEYNAR_API_KEY=
# Mainnet RPC for ENS resolution (Alchemy/Infura). Optional but more reliable
# than the default public endpoint — important for the Mirror direct-route demo.
ETH_RPC_URL=

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Public bot username for the dashboard deep link (no @)
NEXT_PUBLIC_TELEGRAM_BOT_USERNAME=charon_tips_bot
