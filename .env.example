# ── Supabase ──────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Agents (OpenRouter, OpenAI-compatible) ───────────────
OPENROUTER_API_KEY=sk-or-v1-...
# Claude via OpenRouter powers the four reading agents.
# Fallbacks (lib/agents/shared.ts): anthropic/claude-3.5-sonnet, then a free Llama.
OPENROUTER_MODEL=anthropic/claude-sonnet-4

# ── Arc / Circle x402 settlement (pooled reader treasury) ──
# Run `npm run generate-wallets` to create these, then fund the
# addresses at https://faucet.circle.com (select "Arc Testnet").
# The TREASURY wallet holds all readers' deposited USDC and is the
# x402 payer that settles sessions directly to creator wallets.
TREASURY_WALLET_PK=0x...
TREASURY_WALLET_ADDRESS=0x...

# ── Circle Programmable Wallets (creator escrow + offramp) ─
# Developer-controlled wallets API. https://console.circle.com
# Optional: if unset, escrow is ledger-only (still works on testnet).
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
# Blockchain for escrow wallets (e.g. ARB-SEPOLIA / MATIC-AMOY in sandbox).
CIRCLE_WALLET_BLOCKCHAIN=ARB-SEPOLIA

# ── Email (creator payout notifications) ──────────────────
RESEND_API_KEY=
RESEND_FROM="Charon <hello@paywithcharon.xyz>"

# ── App ───────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Max age (minutes) of an on-chain deposit tx we'll still credit. Reusing the
# same tx hash is always blocked (unique constraint); this rejects *stale* txs.
# Defaults to 1440 (24h) if unset.
DEPOSIT_MAX_AGE_MINUTES=1440

# ── New-reader welcome credit ─────────────────────────────
# One-time free balance granted to a reader on first onboarding (USD).
# Lets people try the app without depositing. Defaults to 0.50 if unset.
WELCOME_CREDIT_USD=0.50

# ── Admin access ──────────────────────────────────────────
# Path 1: email allowlist (comma-separated) for Supabase-authed admins.
ADMIN_EMAILS=
# Path 2: ops-admin login at /admin/login with these credentials.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
# Secret used to sign the admin session cookie (falls back to ADMIN_PASSWORD).
ADMIN_SESSION_SECRET=some-long-random-string

# ── Cron auth (Agent 3 reprice, Agent 4 budget) ──────────
# Vercel Cron sends this as a bearer token; set the same value in Vercel.
CRON_SECRET=some-random-string

# ── Optional smoke-test override ──────────────────────────
# SETTLE_SMOKE_TO=0x...   # destination for `npm run settle-smoke` (defaults to treasury)

