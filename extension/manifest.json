{
  "manifest_version": 3,
  "name": "Charon — Tip any creator",
  "version": "0.1.0",
  "description": "Tip the creator of any page in one click — settled instantly on Arc.",
  "permissions": ["storage", "activeTab", "tabs"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Charon"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
